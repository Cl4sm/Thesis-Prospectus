{# Cover / title slide — white top, maroon bottom band #}
<div class="slide flex flex-col" id="slide-{{ slide._index }}">
    {# Main content area — centered in upper portion #}
    <div class="flex-1 flex flex-col items-center text-center px-12 pb-4" style="width:100%;">
        <div class="slide-body cover-body" style="width:100%; flex:1; display:flex; flex-direction:column; align-items:center;">
            {{ slide.body_html | safe }}
        </div>
    </div>
    {# Maroon bottom band #}
    <div class="bg-maroon text-white px-12 flex items-center justify-between shrink-0" style="font-size:32px; padding-top:22px; padding-bottom:22px;">
        <div style="opacity:0.9;">
            Arizona State University · SEFCOM
        </div>
        <div style="opacity:0.9;">
            March 2026
        </div>
    </div>
</div>
