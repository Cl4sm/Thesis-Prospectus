{# Section divider — maroon background, centered white text #}
<div class="slide flex flex-col items-center justify-center text-center px-12 bg-maroon" id="slide-{{ slide._index }}">
    {% if slide.label %}
    <p class="text-2xl md:text-3xl text-white/50 uppercase tracking-widest mb-4">{{ slide.label }}</p>
    {% endif %}
    <h2 class="font-bold text-white mb-6" style="font-size: clamp(4rem, 8vw, 7rem);">{{ slide.title }}</h2>
    <div class="slide-body section-body text-white/70 max-w-[80%]" style="font-size: clamp(1.8rem, 3.5vw, 2.8rem);">
        {{ slide.body_html | safe }}
    </div>
</div>
