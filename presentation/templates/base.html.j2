<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ meta.title }}</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="d3.v7.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        maroon: { DEFAULT: '#8C1D40', dark: '#6A0F30', light: '#F5EDF0' },
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <!-- Prism.js syntax highlighting -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css" rel="stylesheet"/>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-c.min.js"></script>
    <style>
        /* Override Prism defaults for SVG foreignObject code blocks */
        foreignObject pre[class*="language-"] {
            margin: 0 !important;
            padding: 0 !important;
            background: transparent !important;
            border: none !important;
            overflow: visible !important;
        }
        foreignObject code[class*="language-"] {
            font-family: 'JetBrains Mono', monospace !important;
            background: transparent !important;
            text-shadow: none !important;
            white-space: pre !important;
            color: #1a1a1a !important;
            line-height: 1.35 !important;
        }
        foreignObject pre[class*="language-"] code[class*="language-"] {
            line-height: 1.35 !important;
        }
        /* High-contrast token colors for light background */
        foreignObject .token.keyword { color: #0033B3 !important; font-weight: 600; }
        foreignObject .token.function { color: #00627A !important; }
        foreignObject .token.string { color: #067D17 !important; }
        foreignObject .token.comment { color: #8C8C8C !important; }
        foreignObject .token.number { color: #1750EB !important; }
        foreignObject .token.operator,
        foreignObject .token.punctuation { color: #1a1a1a !important; }
        /* Scroll snap for slide navigation — NO animated transitions */
        html, body { margin: 0; padding: 0; overflow: hidden; scroll-behavior: auto; width: 100%; height: 100%; }
        .slides-container {
            width: 100%; height: 100vh;
            overflow-x: hidden;
            overflow-y: scroll;
            scroll-snap-type: y mandatory;
            scroll-behavior: auto;
            scrollbar-width: none;           /* Firefox */
            -ms-overflow-style: none;        /* IE/Edge */
        }
        .slides-container::-webkit-scrollbar {
            display: none;                   /* Chrome/Safari */
        }
        .slide {
            width: 100%; height: 100vh; height: 100dvh;
            overflow: hidden; scroll-snap-align: start;
            box-sizing: border-box;
            position: relative;
        }
        /* Kill any transition/animation Tailwind or browser might inject */
        .slides-container, .slide {
            transition: none !important;
            animation: none !important;
        }

        /* Code syntax highlighting */
        .code-keyword { color: #8BC34A; }
        .code-string { color: #F0A03C; }
        .code-comment { color: #888; font-style: italic; }
        .code-fn { color: #66D9EF; }
        .code-type { color: #A6E3A1; }

        /* Reduced motion */
        @media (prefers-reduced-motion: reduce) {
            * { scroll-behavior: auto !important; }
        }

        /* Markdown body styling */
        .slide-body h1 {
            font-size: clamp(2.7rem, 6.1vw, 4.3rem);
            font-weight: 700;
            color: #111;
            margin-bottom: 0.4rem;
            line-height: 1.15;
        }
        .slide-body ul {
            list-style: none;
            margin: 0; padding: 0;
        }
        .slide-body li {
            font-size: clamp(2.4rem, 4.3vw, 3.2rem);
            color: #222;
            margin-bottom: clamp(0.3rem, 0.8vh, 0.6rem);
            padding-left: 1.4em;
            position: relative;
            line-height: 1.35;
        }
        .slide-body li::before {
            content: "●";
            position: absolute;
            left: 0.15em;
            color: #555;
            font-size: 0.45em;
            top: 0.5em;
        }
        .slide-body p {
            font-size: clamp(2.4rem, 4.3vw, 3.2rem);
            color: #333;
            margin-bottom: clamp(0.3rem, 0.8vh, 0.7rem);
            line-height: 1.35;
        }
        .slide-body h2 {
            font-size: clamp(2.7rem, 4.7vw, 3.8rem);
            font-weight: 700;
            color: #111;
            margin-bottom: 0.4rem;
        }
        .slide-body h3 {
            font-size: clamp(2.4rem, 4.3vw, 3.2rem);
            font-weight: 700;
            color: #111;
            margin-bottom: clamp(0.2rem, 0.5vh, 0.4rem);
            margin-top: clamp(0.5rem, 1vh, 0.8rem);
        }
        .slide-body h3:first-child {
            margin-top: 0;
        }
        .slide-body strong { font-weight: 700; color: #111; }
        .slide-body em { font-style: italic; color: #555; }
        .slide-body code {
            font-family: 'JetBrains Mono', monospace;
            background: #f3f3f3;
            padding: 0.15em 0.4em;
            border-radius: 3px;
            font-size: 0.9em;
        }
        .slide-body pre {
            background: #2D2D2D;
            color: #E0E0E0;
            padding: 1.2rem 1.5rem;
            overflow-x: auto;
            font-size: clamp(0.9rem, 1.5vw, 1.15rem);
            line-height: 1.6;
            margin: 1rem 0;
            border-radius: 4px;
        }
        .slide-body pre code {
            background: none;
            padding: 0;
            font-size: inherit;
            color: inherit;
        }
        .slide-body table {
            width: 100%;
            border-collapse: collapse;
            margin: 1rem 0;
            font-size: clamp(1.05rem, 1.8vw, 1.35rem);
        }
        .slide-body thead { border-bottom: 2px solid #333; }
        .slide-body th { padding: 0.75rem 1rem; text-align: left; font-weight: 600; }
        .slide-body td { padding: 0.75rem 1rem; border-bottom: 1px solid #ddd; }
        .slide-body blockquote {
            border-left: 4px solid #8C1D40;
            padding-left: 1rem;
            margin: 1rem 0;
            color: #555;
            font-style: italic;
        }

        /* Slide footnote — light grey, bottom-left */
        .slide-footnote {
            position: absolute;
            bottom: 1.2rem;
            left: 2rem;
            font-size: clamp(0.75rem, 1.1vw, 0.95rem);
            color: #999;
            line-height: 1.4;
            max-width: 70%;
        }
        .slide-footnote a {
            color: #999;
            text-decoration: underline;
            text-decoration-color: #ccc;
        }

        /* Diagram / SVG scaling — fill available slide space */
        .slide-body > svg,
        .slide-body > div > svg,
        .slide-body > p > svg {
            width: 100%;
            max-width: none;
            height: auto;
            display: block;
            margin-left: auto;
            margin-right: auto;
        }
        /* D3 chart containers */
        .slide-body > div[id^="chart-"] {
            width: 100%;
            max-width: none;
        }
        .slide-body > div[id^="chart-"] svg {
            width: 100%;
            max-width: none;
            height: auto;
        }

        /* Cover slide body overrides */
        .cover-body h1 {
            font-size: clamp(2.8rem, 6vw, 4.5rem);
            margin-bottom: 1rem;
        }
        .cover-body h2 {
            font-size: clamp(2.4rem, 5vw, 3.8rem);
            font-weight: 400;
            color: #555;
            margin-bottom: 2rem;
        }
        .cover-body p {
            font-size: clamp(1.6rem, 3vw, 2.2rem);
            color: #444;
            margin-bottom: 0.3rem;
        }
        .cover-body strong {
            font-size: clamp(1.4rem, 2.5vw, 2rem);
            display: block;
            margin-bottom: 1rem;
        }

        /* Section divider body overrides */
        .section-body p {
            color: rgba(255,255,255,0.7);
            /* font-size: inherit;*/
        }
    </style>
</head>
<body class="bg-white text-gray-900 font-sans m-0 p-0 h-screen overflow-hidden">
    <script>
    // === Animation Step System (must load before slides) ===
    window._animQueue = [];
    window.slideAnimations = {};


    window.registerSlideAnimation = function(slideIndex, config) {
        window.slideAnimations[slideIndex] = {
            steps: config.steps || [],
            currentStep: -1,
            mode: config.mode || 'step'
        };
    };

    // Helper: create a step from SVG element IDs + options
    window.makeStep = function(svgIds, options) {
        options = options || {};
        return {
            show: function(instant) {
                (svgIds || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (!el) return;
                    el.setAttribute('opacity', '1');
                    el.style.opacity = '1';
                    if (!instant && !(el instanceof SVGElement)) {
                        el.animate([{ opacity: 0, transform: 'translateY(8px)' }, { opacity: 1, transform: 'translateY(0)' }], { duration: 250, easing: 'ease-out', fill: 'forwards' });
                    }
                });
                (options.codeLines || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (el) {
                        el.style.borderLeftColor = options.highlightColor || '#FFB300';
                        el.style.backgroundColor = options.highlightBg || 'rgba(255, 179, 0, 0.15)';
                    }
                });
                (options.showEls || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (el) {
                        el.style.opacity = '1';
                        el.style.transform = 'translateY(0)';
                        if (!instant && !(el instanceof SVGElement)) {
                            el.animate([{ opacity: 0, transform: 'translateY(8px)' }, { opacity: 1, transform: 'translateY(0)' }], { duration: 250, easing: 'ease-out', fill: 'forwards' });
                        }
                    }
                });
                (options.addClasses || []).forEach(function(spec) {
                    var el = document.getElementById(spec.id);
                    if (el) el.classList.add(spec.cls);
                });
            },
            hide: function() {
                (svgIds || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (!el) return;
                    // Cancel WAAPI animations so fill:forwards doesn't override
                    el.getAnimations().forEach(function(a) { a.cancel(); });
                    el.setAttribute('opacity', '0');
                    el.style.opacity = '0';
                });
                (options.codeLines || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (el) {
                        el.style.borderLeftColor = 'transparent';
                        el.style.backgroundColor = 'transparent';
                    }
                });
                (options.showEls || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (el) {
                        el.getAnimations().forEach(function(a) { a.cancel(); });
                        el.style.opacity = '0';
                    }
                });
                (options.addClasses || []).forEach(function(spec) {
                    var el = document.getElementById(spec.id);
                    if (el) el.classList.remove(spec.cls);
                });
            }
        };
    };
    </script>

    <div class="slides-container" id="slidesContainer">
        {% for slide in slides %}
        {%- include slide._template %}
        {% endfor %}
    </div>

    <!-- Slide number -->
    <div id="slideNumber" class="fixed bottom-5 right-6 text-lg text-gray-400 z-50 pointer-events-none"></div>

    <!-- Presenter notes data -->
    <script id="slide-notes" type="application/json">
    [{% for slide in slides %}{{ slide.notes_html | tojson }}{% if not loop.last %},{% endif %}{% endfor %}]
    </script>

    <script>
        const container = document.getElementById('slidesContainer');
        const slides = document.querySelectorAll('.slide');
        const notesData = JSON.parse(document.getElementById('slide-notes').textContent);
        let current = 0;
        let wheelCooldown = false;
        let presenterWin = null;
        let presenterTimerInterval = null;

        // Restore slide position from URL hash on load
        (function restoreFromHash() {
            const m = location.hash.match(/^#slide-(\d+)$/);
            if (m) {
                const idx = parseInt(m[1], 10) - 1;
                if (idx >= 0 && idx < slides.length) {
                    current = idx;
                    container.style.scrollSnapType = 'none';
                    container.scrollTop = idx * container.clientHeight;
                    requestAnimationFrame(() => {
                        requestAnimationFrame(() => {
                            container.style.scrollSnapType = 'y mandatory';
                        });
                    });
                }
            }
        })();

        // === Animation step controller ===
        function resetSlideAnim(idx) {
            const a = window.slideAnimations[idx];
            if (!a) return;
            for (let i = a.steps.length - 1; i >= 0; i--) a.steps[i].hide();
            a.currentStep = -1;
        }

        function showAllSlideAnim(idx) {
            const a = window.slideAnimations[idx];
            if (!a) return;
            for (let i = 0; i < a.steps.length; i++) a.steps[i].show(true);
            a.currentStep = a.steps.length - 1;
        }

        function handleForward() {
            const a = window.slideAnimations[current];
            if (a && a.mode === 'step' && a.currentStep < a.steps.length - 1) {
                a.currentStep++;
                a.steps[a.currentStep].show(false);
                update();
            } else {
                goTo(current + 1, 'forward');
            }
        }

        function handleBackward() {
            const a = window.slideAnimations[current];
            if (a && a.mode === 'step' && a.currentStep >= 0) {
                a.steps[a.currentStep].hide();
                a.currentStep--;
                update();
            } else {
                goTo(current - 1, 'backward');
            }
        }

        function update() {
            const snEl = document.getElementById('slideNumber');
            if (current === 0 || current === slides.length - 1) {
                snEl.textContent = '';
            } else {
                snEl.textContent = current + 1;
            }
            // Persist current slide in URL hash so refresh returns here
            history.replaceState(null, '', '#slide-' + (current + 1));
            if (presenterWin && !presenterWin.closed) {
                sendPresenterUpdate();
            }
        }

        function goTo(i, direction) {
            if (i < 0 || i >= slides.length) return;
            current = i;
            // Use direct scrollTop for truly instant navigation (no snap animation)
            container.style.scrollSnapType = 'none';
            container.scrollTop = i * container.clientHeight;
            // Re-enable snap after the jump so manual scrolling still snaps
            requestAnimationFrame(() => {
                requestAnimationFrame(() => {
                    container.style.scrollSnapType = 'y mandatory';
                });
            });
            // Handle animation state based on navigation direction
            if (direction === 'forward') {
                resetSlideAnim(i);
            } else if (direction === 'backward') {
                showAllSlideAnim(i);
            } else {
                // Direct jump (g+number, Home, End): show all animations
                showAllSlideAnim(i);
            }
            update();
        }

        // Listen for navigation commands from presenter window via postMessage
        window.addEventListener('message', e => {
            if (e.data && e.data.type === 'navigate') {
                goTo(e.data.index);
            } else if (e.data && e.data.type === 'navigateDirection') {
                if (e.data.direction === 'forward') handleForward();
                else if (e.data.direction === 'backward') handleBackward();
            }
        });

        // Vim-style g+number navigation
        let gBuffer = '';
        let gTimeout = null;
        let gWaiting = false;

        document.addEventListener('keydown', e => {
            const k = e.key;

            // If we're collecting digits after 'g'
            if (gWaiting) {
                if (k >= '0' && k <= '9') {
                    e.preventDefault();
                    gBuffer += k;
                    clearTimeout(gTimeout);
                    gTimeout = setTimeout(() => {
                        const num = parseInt(gBuffer, 10);
                        if (num >= 1 && num <= slides.length) goTo(num - 1);
                        gBuffer = '';
                        gWaiting = false;
                    }, 600);
                    return;
                } else {
                    // Non-digit pressed, cancel g-mode
                    clearTimeout(gTimeout);
                    gBuffer = '';
                    gWaiting = false;
                }
            }

            if (k === 'g') { e.preventDefault(); gWaiting = true; gBuffer = ''; return; }

            if (['ArrowRight','ArrowDown',' ','PageDown'].includes(k)) { e.preventDefault(); handleForward(); }
            else if (['ArrowLeft','ArrowUp','PageUp'].includes(k)) { e.preventDefault(); handleBackward(); }
            else if (k === 'Home') { e.preventDefault(); goTo(0); }
            else if (k === 'End') { e.preventDefault(); goTo(slides.length - 1); }
            else if (k === 'p' || k === 'P') { e.preventDefault(); openPresenterView(); }
        });

        container.addEventListener('wheel', e => {
            if (wheelCooldown) return;
            wheelCooldown = true;
            if (e.deltaY > 0) handleForward();
            else if (e.deltaY < 0) handleBackward();
            setTimeout(() => wheelCooldown = false, 600);
        }, { passive: true });

        // Touch
        let ty = 0;
        container.addEventListener('touchstart', e => { ty = e.touches[0].clientY; });
        container.addEventListener('touchend', e => {
            const d = ty - e.changedTouches[0].clientY;
            if (Math.abs(d) > 50) { if (d > 0) handleForward(); else handleBackward(); }
        });

        // Intersection Observer
        const obs = new IntersectionObserver(entries => {
            entries.forEach(e => {
                if (e.isIntersecting) { current = Array.from(slides).indexOf(e.target); update(); }
            });
        }, { threshold: 0.5 });
        slides.forEach(s => obs.observe(s));

        // Re-focus main window when presenter view closes
        setInterval(() => {
            if (presenterWin && presenterWin.closed) {
                presenterWin = null;
                if (presenterTimerInterval) { clearInterval(presenterTimerInterval); presenterTimerInterval = null; }
                window.focus();
                document.body.focus();
            }
        }, 500);

        // === PRESENTER VIEW ===
        // Send slide data to presenter window via postMessage (works on file://)
        function sendPresenterUpdate() {
            if (!presenterWin || presenterWin.closed) return;
            const titleEl = slides[current].querySelector('[class*="bg-maroon"]') ||
                            slides[current].querySelector('h2') ||
                            slides[current].querySelector('h1');
            presenterWin.postMessage({
                type: 'slideUpdate',
                index: current,
                total: slides.length,
                title: titleEl ? titleEl.textContent.trim() : '',
                notes: notesData[current] || ''
            }, '*');
        }

        function openPresenterView() {
            if (presenterWin && !presenterWin.closed) {
                presenterWin.focus();
                sendPresenterUpdate();
                return;
            }
            // Build presenter HTML as string array, inject JS via DOM to avoid parser issues
            const pvHTML = [
                '<!DOCTYPE html><html><head><title>Presenter Notes</title>',
                '<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">',
                '<style>',
                '* { box-sizing: border-box; margin: 0; padding: 0; }',
                'body { font-family: "Inter", sans-serif; background: #1a1a1a; color: #eee; padding: 24px; height: 100vh; display: flex; flex-direction: column; }',
                '.header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; flex-shrink: 0; }',
                '.slide-info { font-size: 28px; font-weight: 700; color: #fff; }',
                '.slide-title { font-size: 16px; color: #999; margin-top: 4px; }',
                '.timer { font-size: 24px; font-weight: 600; color: #8C1D40; font-variant-numeric: tabular-nums; }',
                '.notes-container { flex: 1; overflow-y: auto; background: #222; border-radius: 8px; padding: 24px; }',
                '.notes-container h1, .notes-container h2, .notes-container h3 { color: #fff; margin-bottom: 8px; }',
                '.notes-container p { font-size: 18px; line-height: 1.7; color: #ddd; margin-bottom: 12px; }',
                '.notes-container li { font-size: 18px; line-height: 1.7; color: #ddd; margin-bottom: 8px; margin-left: 20px; }',
                '.notes-container strong { color: #fff; }',
                '.notes-container code { background: #333; padding: 2px 6px; border-radius: 3px; font-size: 0.9em; }',
                '.empty-notes { color: #666; font-style: italic; font-size: 18px; }',
                '.controls { display: flex; gap: 12px; margin-top: 16px; flex-shrink: 0; }',
                '.controls button { background: #333; border: none; color: #eee; padding: 10px 20px; border-radius: 6px; font-size: 16px; cursor: pointer; font-family: inherit; }',
                '.controls button:hover { background: #444; }',
                '.timer-row { display: flex; align-items: center; gap: 10px; }',
                '.timer-btn { background: none; border: 1px solid #555; color: #ccc; width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-size: 14px; display: flex; align-items: center; justify-content: center; padding: 0; line-height: 1; }',
                '.timer-btn:hover { border-color: #8C1D40; color: #fff; }',
                '.timer-btn.active { background: #8C1D40; border-color: #8C1D40; color: #fff; }',
                '.timer.paused { color: #666; }',
                '</style></head><body>',
                '<div class="header"><div>',
                '  <div class="slide-info" id="pv-slide">Slide 1 / ' + slides.length + '</div>',
                '  <div class="slide-title" id="pv-title"></div>',
                '</div>',
                '<div class="timer-row">',
                '  <div class="timer" id="pv-timer">00:00</div>',
                '  <button class="timer-btn" id="btn-timer-toggle" title="Start timer">&#9654;</button>',
                '  <button class="timer-btn" id="btn-timer-reset" title="Reset timer">&#8634;</button>',
                '</div></div>',
                '<div class="notes-container" id="pv-notes"><p class="empty-notes">No notes for this slide</p></div>',
                '<div class="controls">',
                '  <button id="btn-prev">&larr; Prev</button>',
                '  <button id="btn-next">Next &rarr;</button>',
                '</div>',
                '</body></html>'
            ].join('\n');

            presenterWin = window.open('', 'PresenterView', 'width=800,height=600');
            if (!presenterWin) {
                alert('Popup blocked! Please allow popups for this page, then press P again.');
                return;
            }
            presenterWin.document.write(pvHTML);
            presenterWin.document.close();

            // Inject script via DOM to avoid closing-tag parser issues
            const pvScript = presenterWin.document.createElement('script');
            pvScript.textContent = `
                var currentSlide = 0;

                // === TIMER ===
                var timerRunning = false;
                var elapsedSeconds = 0;
                var timerInterval = null;
                var timerEl = document.getElementById('pv-timer');
                var toggleBtn = document.getElementById('btn-timer-toggle');
                var resetBtn = document.getElementById('btn-timer-reset');

                function formatTime(secs) {
                    var m = String(Math.floor(secs / 60)).padStart(2, '0');
                    var s = String(secs % 60).padStart(2, '0');
                    return m + ':' + s;
                }
                function updateTimerDisplay() {
                    timerEl.textContent = formatTime(elapsedSeconds);
                }
                function startTimer() {
                    if (timerRunning) return;
                    timerRunning = true;
                    toggleBtn.innerHTML = '&#9646;&#9646;';
                    toggleBtn.title = 'Pause timer';
                    toggleBtn.classList.add('active');
                    timerEl.classList.remove('paused');
                    timerInterval = setInterval(function() {
                        elapsedSeconds++;
                        updateTimerDisplay();
                    }, 1000);
                }
                function pauseTimer() {
                    if (!timerRunning) return;
                    timerRunning = false;
                    clearInterval(timerInterval);
                    toggleBtn.innerHTML = '&#9654;';
                    toggleBtn.title = 'Resume timer';
                    toggleBtn.classList.remove('active');
                    timerEl.classList.add('paused');
                }
                function resetTimer() {
                    pauseTimer();
                    elapsedSeconds = 0;
                    updateTimerDisplay();
                    toggleBtn.innerHTML = '&#9654;';
                    toggleBtn.title = 'Start timer';
                }
                toggleBtn.addEventListener('click', function() {
                    if (timerRunning) pauseTimer(); else startTimer();
                });
                resetBtn.addEventListener('click', resetTimer);

                // === SLIDE UPDATES ===
                window.addEventListener('message', function(e) {
                    if (!e.data || !e.data.type) return;
                    if (e.data.type === 'slideUpdate') {
                        currentSlide = e.data.index;
                        document.getElementById('pv-slide').textContent = 'Slide ' + (e.data.index + 1) + ' / ' + e.data.total;
                        document.getElementById('pv-title').textContent = e.data.title || '';
                        var notesEl = document.getElementById('pv-notes');
                        if (e.data.notes) { notesEl.innerHTML = e.data.notes; }
                        else { notesEl.innerHTML = '<p class="empty-notes">No notes for this slide</p>'; }
                    }
                });

                // === NAVIGATION ===
                function navDirection(dir) {
                    window.opener.postMessage({ type: 'navigateDirection', direction: dir }, '*');
                }
                document.getElementById('btn-prev').addEventListener('click', function() { navDirection('backward'); });
                document.getElementById('btn-next').addEventListener('click', function() { navDirection('forward'); });
                document.addEventListener('keydown', function(e) {
                    var k = e.key;
                    if (['ArrowRight','ArrowDown',' ','PageDown'].indexOf(k) !== -1) { e.preventDefault(); navDirection('forward'); }
                    else if (['ArrowLeft','ArrowUp','PageUp'].indexOf(k) !== -1) { e.preventDefault(); navDirection('backward'); }
                });
            `;
            presenterWin.document.body.appendChild(pvScript);

            sendPresenterUpdate();
        }

        // Process deferred animation registrations now that DOM is complete
        window._animQueue.forEach(function(fn) { fn(); });

        update();
    </script>
</body>
</html>
