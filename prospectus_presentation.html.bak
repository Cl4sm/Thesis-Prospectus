  <!-- Arrow 1 -->
  <path d="M 250 140 L 290 140" stroke="#333" stroke-width="2.5" fill="none" marker-end="url(#prep-arr)"/>

  <!-- Stage 2: Analyzer -->
  <rect x="300" y="80" width="200" height="120" rx="8" fill="#fafafa" stroke="#FF9800" stroke-width="2"/>
  <rect x="300" y="80" width="200" height="35" rx="8" fill="#fff3e0"/>
  <text x="400" y="103" font-size="16" font-weight="bold" text-anchor="middle" fill="#E65100" font-family="Inter, sans-serif">Analyzer</text>
  <line x1="300" x2="500" y1="115" y2="115" stroke="#FF9800" stroke-width="1"/>
  <text x="400" y="138" font-size="12" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">Extracts structural information:</text>
  <text x="400" y="155" font-size="12" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">Control flow graphs, call graphs,</text>
  <text x="400" y="172" font-size="12" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">type hierarchies, data flow</text>

  <!-- Arrow 2 -->
  <path d="M 500 140 L 540 140" stroke="#333" stroke-width="2.5" fill="none" marker-end="url(#prep-arr)"/>

  <!-- Stage 3: Indexer -->
  <rect x="550" y="80" width="200" height="120" rx="8" fill="#fafafa" stroke="#2196F3" stroke-width="2"/>
  <rect x="550" y="80" width="200" height="35" rx="8" fill="#e3f2fd"/>
  <text x="650" y="103" font-size="16" font-weight="bold" text-anchor="middle" fill="#1565C0" font-family="Inter, sans-serif">Indexer</text>
