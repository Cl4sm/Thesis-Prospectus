</div>
        
<div class="slide flex flex-col" id="slide-31">
    <div class="bg-maroon text-white font-normal px-10 md:px-14 py-5 md:py-7 border-b-4 border-maroon-dark shrink-0" style="font-size: clamp(3.3rem, 5.7vw, 4.8rem);">
        Target Preparation
    </div>
    <div class="flex-1 px-8 md:px-12 py-3 md:py-5 overflow-hidden flex flex-col justify-center">
        <div class="slide-body">
            <svg viewBox="0 0 1050 350" style="width:100%; margin:0 auto; display:block;" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="prep-arr" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
      <polygon points="0 0, 8 3, 0 6" fill="#333"/>
