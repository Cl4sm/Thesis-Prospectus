<svg viewBox="0 0 1050 400" style="width:100%; margin:0 auto; display:block;" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="dyn-gram-arr" markerWidth="8" markerHeight="8" refX="7" refY="3" orient="auto">
