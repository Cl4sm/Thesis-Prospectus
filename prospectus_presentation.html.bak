  <text x="650" y="138" font-size="12" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">Builds searchable indices:</text>
  <text x="650" y="155" font-size="12" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">AST-based code search,</text>
  <text x="650" y="172" font-size="12" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">semantic symbol queries</text>

  <!-- Arrow 3 -->
  <path d="M 750 140 L 790 140" stroke="#333" stroke-width="2.5" fill="none" marker-end="url(#prep-arr)"/>

  <!-- Stage 4: DiffGuy -->
  <rect x="800" y="80" width="220" height="120" rx="8" fill="#fafafa" stroke="#9C27B0" stroke-width="2"/>
  <rect x="800" y="80" width="220" height="35" rx="8" fill="#f3e5f5"/>
  <text x="910" y="103" font-size="16" font-weight="bold" text-anchor="middle" fill="#7B1FA2" font-family="Inter, sans-serif">DiffGuy</text>
  <line x1="800" x2="1020" y1="115" y2="115" stroke="#9C27B0" stroke-width="1"/>
  <text x="910" y="138" font-size="12" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">Tracks code changes:</text>
  <text x="910" y="155" font-size="12" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">Diffs between versions,</text>
  <text x="910" y="172" font-size="12" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">delta analysis foundation</text>

  <!-- Bottom insight -->
  <rect x="50" y="240" width="970" height="80" rx="6" fill="#f5f5f5" stroke="#666" stroke-width="1"/>
  <text x="525" y="270" font-size="14" font-weight="bold" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">Output: Instrumented binaries, normalized code graphs, searchable indices</text>
  <text x="525" y="295" font-size="13" text-anchor="middle" fill="#666" font-family="Inter, sans-serif">These foundations enable all downstream agents: fuzzers have coverage signals, LLMs have semantic code understanding, root-cause analysis has debug symbols</text>
</svg>
