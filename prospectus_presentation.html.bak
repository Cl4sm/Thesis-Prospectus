<script>
window._animQueue.push(function() {
  var svg = document.querySelector('svg');
  if (!svg) return;
  var slideEl = svg.closest('.slide');
  var slides = document.querySelectorAll('.slide');
  var idx = Array.from(slides).indexOf(slideEl);
  if (idx < 0) return;

  // Helper to set opacity on elements
  function setOpacity(selector, opacity) {
    var el = svg.querySelector(selector);
    if (el) {
      el.style.opacity = opacity;
      el.setAttribute('opacity', opacity);
    }
  }

  // Set all groups to 0 opacity initially
  var groups = [
    '[x="18"]',  // Target Preparation
    '[x="214"]', // Pre Analysis (STATIC)
    '[x="336"]', // Dynamic analysis (DYNAMIC and its columns)
    '[x="770"]', // Root-cause & Patching
    '[x="30"][y="355"]' // Analysis Graph
  ];

  // Actually, let's use a different approach with SVG groups
  window.registerSlideAnimation(idx, {
    mode: 'step',
    steps: [
      // Step 1: Target Preparation
      {
        show: function(instant) {
          var el = document.querySelector('[data-step-1]') || svg.querySelector('rect[x="18"][y="100"]');
          // Show all elements in target prep box
          var rects = svg.querySelectorAll('rect[x="18"][y="100"], rect[x="28"], rect[x="103"]');
          rects.forEach(function(r) { r.style.opacity = '1'; });
          var paths = svg.querySelectorAll('path[d*="M 178"]');
          paths.forEach(function(p) { p.style.opacity = '0'; });
        },
        hide: function() {}
      },
      // Step 2: Static Analysis
      {
        show: function(instant) {
          var els = svg.querySelectorAll('rect[x="214"], rect[x="228"]');
          els.forEach(function(e) { e.style.opacity = '1'; });
        },
        hide: function() {}
      },
      // Step 3: Dynamic Analysis + Seeds Pool
      {
        show: function(instant) {
          var els = svg.querySelectorAll('rect[x="340"], rect[x="462"], rect[x="594"], rect[x="340"][y="270"]');
          els.forEach(function(e) { e.style.opacity = '1'; });
        },
        hide: function() {}
      },
      // Step 4: Root-cause & Patching
      {
        show: function(instant) {
          var els = svg.querySelectorAll('rect[x="770"], rect[x="780"], rect[x="888"]');
          els.forEach(function(e) { e.style.opacity = '1'; });
        },
        hide: function() {}
      },
      // Step 5: Analysis Graph
      {
        show: function(instant) {
          var el = svg.querySelector('rect[x="30"][y="355"]');
          if (el) el.style.opacity = '1';
        },
        hide: function() {}
      }
    ]
  });
});
</script>
