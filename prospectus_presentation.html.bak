  <rect x="355" y="70" width="90" height="55" rx="4" fill="#fff" stroke="#ddd" stroke-width="1.5"/>
  <text x="400" y="92" font-size="10" font-weight="600" text-anchor="middle" fill="#333" font-family="Inter, sans-serif">Tenda</text>
