<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dissertation Prospectus Defense - Wil Gibbs</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="d3.v7.min.js"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        maroon: { DEFAULT: '#8C1D40', dark: '#6A0F30', light: '#F5EDF0' },
                    },
                    fontFamily: {
                        sans: ['Inter', 'system-ui', 'sans-serif'],
                        mono: ['JetBrains Mono', 'monospace'],
                    }
                }
            }
        }
    </script>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <!-- Prism.js syntax highlighting -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/themes/prism.min.css" rel="stylesheet"/>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/prism.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/prism/1.29.0/components/prism-c.min.js"></script>
    <style>
        /* Override Prism defaults for SVG foreignObject code blocks */
        foreignObject pre[class*="language-"] {
            margin: 0 !important;
            padding: 0 !important;
            background: transparent !important;
            border: none !important;
            overflow: visible !important;
        }
        foreignObject code[class*="language-"] {
            font-family: 'JetBrains Mono', monospace !important;
            background: transparent !important;
            text-shadow: none !important;
            white-space: pre !important;
            color: #1a1a1a !important;
            line-height: 1.35 !important;
        }
        foreignObject pre[class*="language-"] code[class*="language-"] {
            line-height: 1.35 !important;
        }
        /* High-contrast token colors for light background */
        foreignObject .token.keyword { color: #0033B3 !important; font-weight: 600; }
        foreignObject .token.function { color: #00627A !important; }
        foreignObject .token.string { color: #067D17 !important; }
        foreignObject .token.comment { color: #8C8C8C !important; }
        foreignObject .token.number { color: #1750EB !important; }
        foreignObject .token.operator,
        foreignObject .token.punctuation { color: #1a1a1a !important; }
        /* Scroll snap for slide navigation — NO animated transitions */
        html, body { margin: 0; padding: 0; overflow: hidden; scroll-behavior: auto; width: 100%; height: 100%; }
        .slides-container {
            width: 100%; height: 100vh;
            overflow-x: hidden;
            overflow-y: scroll;
            scroll-snap-type: y mandatory;
            scroll-behavior: auto;
            scrollbar-width: none;           /* Firefox */
            -ms-overflow-style: none;        /* IE/Edge */
        }
        .slides-container::-webkit-scrollbar {
            display: none;                   /* Chrome/Safari */
        }
        .slide {
            width: 100%; height: 100vh; height: 100dvh;
            overflow: hidden; scroll-snap-align: start;
            box-sizing: border-box;
            position: relative;
        }
        /* Kill any transition/animation Tailwind or browser might inject */
        .slides-container, .slide {
            transition: none !important;
            animation: none !important;
        }

        /* Code syntax highlighting */
        .code-keyword { color: #8BC34A; }
        .code-string { color: #F0A03C; }
        .code-comment { color: #888; font-style: italic; }
        .code-fn { color: #66D9EF; }
        .code-type { color: #A6E3A1; }

        /* Reduced motion */
        @media (prefers-reduced-motion: reduce) {
            * { scroll-behavior: auto !important; }
        }

        /* Markdown body styling */
        .slide-body h1 {
            font-size: clamp(2.7rem, 6.1vw, 4.3rem);
            font-weight: 700;
            color: #111;
            margin-bottom: 0.4rem;
            line-height: 1.15;
        }
        .slide-body ul {
            list-style: none;
            margin: 0; padding: 0;
        }
        .slide-body li {
            font-size: clamp(2.4rem, 4.3vw, 3.2rem);
            color: #222;
            margin-bottom: clamp(0.3rem, 0.8vh, 0.6rem);
            padding-left: 1.4em;
            position: relative;
            line-height: 1.35;
        }
        .slide-body li::before {
            content: "●";
            position: absolute;
            left: 0.15em;
            color: #555;
            font-size: 0.45em;
            top: 0.5em;
        }
        .slide-body p {
            font-size: clamp(2.4rem, 4.3vw, 3.2rem);
            color: #333;
            margin-bottom: clamp(0.3rem, 0.8vh, 0.7rem);
            line-height: 1.35;
        }
        .slide-body h2 {
            font-size: clamp(2.7rem, 4.7vw, 3.8rem);
            font-weight: 700;
            color: #111;
            margin-bottom: 0.4rem;
        }
        .slide-body h3 {
            font-size: clamp(2.4rem, 4.3vw, 3.2rem);
            font-weight: 700;
            color: #111;
            margin-bottom: clamp(0.2rem, 0.5vh, 0.4rem);
            margin-top: clamp(0.5rem, 1vh, 0.8rem);
        }
        .slide-body h3:first-child {
            margin-top: 0;
        }
        .slide-body strong { font-weight: 700; color: #111; }
        .slide-body em { font-style: italic; color: #555; }
        .slide-body code {
            font-family: 'JetBrains Mono', monospace;
            background: #f3f3f3;
            padding: 0.15em 0.4em;
            border-radius: 3px;
            font-size: 0.9em;
        }
        .slide-body pre {
            background: #2D2D2D;
            color: #E0E0E0;
            padding: 1.2rem 1.5rem;
            overflow-x: auto;
            font-size: clamp(0.9rem, 1.5vw, 1.15rem);
            line-height: 1.6;
            margin: 1rem 0;
            border-radius: 4px;
        }
        .slide-body pre code {
            background: none;
            padding: 0;
            font-size: inherit;
            color: inherit;
        }
        .slide-body table {
            width: 100%;
            border-collapse: collapse;
            margin: 1rem 0;
            font-size: clamp(1.05rem, 1.8vw, 1.35rem);
        }
        .slide-body thead { border-bottom: 2px solid #333; }
        .slide-body th { padding: 0.75rem 1rem; text-align: left; font-weight: 600; }
        .slide-body td { padding: 0.75rem 1rem; border-bottom: 1px solid #ddd; }
        .slide-body blockquote {
            border-left: 4px solid #8C1D40;
            padding-left: 1rem;
            margin: 1rem 0;
            color: #555;
            font-style: italic;
        }

        /* Slide footnote — light grey, bottom-left */
        .slide-footnote {
            position: absolute;
            bottom: 1.2rem;
            left: 2rem;
            font-size: clamp(0.75rem, 1.1vw, 0.95rem);
            color: #999;
            line-height: 1.4;
            max-width: 70%;
        }
        .slide-footnote a {
            color: #999;
            text-decoration: underline;
            text-decoration-color: #ccc;
        }

        /* Diagram / SVG scaling — fill available slide space */
        .slide-body > svg,
        .slide-body > div > svg,
        .slide-body > p > svg {
            width: 100%;
            max-width: none;
            height: auto;
            display: block;
            margin-left: auto;
            margin-right: auto;
        }
        /* D3 chart containers */
        .slide-body > div[id^="chart-"] {
            width: 100%;
            max-width: none;
        }
        .slide-body > div[id^="chart-"] svg {
            width: 100%;
            max-width: none;
            height: auto;
        }

        /* Cover slide body overrides */
        .cover-body h1 {
            font-size: clamp(2.2rem, 5vw, 3.5rem);
            margin-bottom: 0.75rem;
        }
        .cover-body h2 {
            font-size: clamp(1.5rem, 3vw, 2.2rem);
            font-weight: 400;
            color: #555;
            margin-bottom: 2rem;
        }
        .cover-body p {
            font-size: clamp(1rem, 1.8vw, 1.3rem);
            color: #444;
            margin-bottom: 0.3rem;
        }
        .cover-body strong {
            font-size: clamp(1.2rem, 2.2vw, 1.6rem);
            display: block;
            margin-bottom: 1rem;
        }

        /* Section divider body overrides */
        .section-body p {
            color: rgba(255,255,255,0.7);
            font-size: clamp(1.1rem, 2vw, 1.5rem);
        }
    </style>
</head>
<body class="bg-white text-gray-900 font-sans m-0 p-0 h-screen overflow-hidden">
    <script>
    // === Animation Step System (must load before slides) ===
    window._animQueue = [];
    window.slideAnimations = {};


    window.registerSlideAnimation = function(slideIndex, config) {
        window.slideAnimations[slideIndex] = {
            steps: config.steps || [],
            currentStep: -1,
            mode: config.mode || 'step'
        };
    };

    // Helper: create a step from SVG element IDs + options
    window.makeStep = function(svgIds, options) {
        options = options || {};
        return {
            show: function(instant) {
                (svgIds || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (!el) return;
                    el.setAttribute('opacity', '1');
                    el.style.opacity = '1';
                    if (!instant) {
                        el.animate([
                            { opacity: 0, transform: 'translateY(8px)' },
                            { opacity: 1, transform: 'translateY(0)' }
                        ], { duration: 250, easing: 'ease-out' });
                    }
                });
                (options.codeLines || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (el) {
                        el.style.borderLeftColor = options.highlightColor || '#FFB300';
                        el.style.backgroundColor = options.highlightBg || 'rgba(255, 179, 0, 0.15)';
                    }
                });
                (options.showEls || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (el) {
                        el.style.opacity = '1';
                        el.style.transform = 'translateY(0)';
                        if (!instant) {
                            el.animate([
                                { opacity: 0, transform: 'translateY(8px)' },
                                { opacity: 1, transform: 'translateY(0)' }
                            ], { duration: 250, easing: 'ease-out' });
                        }
                    }
                });
                (options.addClasses || []).forEach(function(spec) {
                    var el = document.getElementById(spec.id);
                    if (el) el.classList.add(spec.cls);
                });
            },
            hide: function() {
                (svgIds || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (!el) return;
                    // Cancel WAAPI animations so fill:forwards doesn't override
                    el.getAnimations().forEach(function(a) { a.cancel(); });
                    el.setAttribute('opacity', '0');
                    el.style.opacity = '0';
                });
                (options.codeLines || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (el) {
                        el.style.borderLeftColor = 'transparent';
                        el.style.backgroundColor = 'transparent';
                    }
                });
                (options.showEls || []).forEach(function(id) {
                    var el = document.getElementById(id);
                    if (el) {
                        el.getAnimations().forEach(function(a) { a.cancel(); });
                        el.style.opacity = '0';
                    }
                });
                (options.addClasses || []).forEach(function(spec) {
                    var el = document.getElementById(spec.id);
                    if (el) el.classList.remove(spec.cls);
                });
            }
        };
    };
    </script>

    <div class="slides-container" id="slidesContainer">
        
<div class="slide flex flex-col" id="slide-1">
    
    <div class="flex-1 flex flex-col items-center justify-center text-center px-12 pb-4">
        <div class="slide-body cover-body">
            <h1>Towards Accurate, Complete, and Scalable Autonomous Software Vulnerability Discovery</h1>
<h2>Dissertation Prospectus</h2>
<p><strong>Wil Gibbs</strong></p>
<p>Committee: Adam Doupé (Co-Chair), Fish Wang (Co-Chair) Yan Shoshitaishvili, Adil Ahmad</p>
        </div>
    </div>
    
    <div class="bg-maroon text-white px-12 py-5 flex items-center justify-between shrink-0">
        <div class="text-base md:text-lg opacity-90">
            Arizona State University · SEFCOM
        </div>
        <div class="text-base md:text-lg opacity-90">
            March 2026
        </div>
    </div>
</div>
        
<div class="slide flex flex-col" id="slide-2">
    <div class="bg-maroon text-white font-normal px-10 md:px-14 py-5 md:py-7 border-b-4 border-maroon-dark shrink-0" style="font-size: clamp(3.3rem, 5.7vw, 4.8rem);">
        Software Vulnerabilities at Scale
    </div>
    <div class="flex-1 px-8 md:px-12 py-3 md:py-5 overflow-hidden flex flex-col justify-center">
        <div class="slide-body">
            <div style="display:flex; gap:2rem; margin:0.5rem auto; align-items:stretch;">
  <div id="chart-cve" style="flex:1; min-width:0;"></div>
  <div id="chart-iot" style="flex:1; min-width:0;"></div>
</div>
<script>
window.addEventListener("load", function() {
  // CVE data (source: CVE Find)
  const cveData = [
    {year: 2015, count: 7538}, {year: 2016, count: 7076}, {year: 2017, count: 17713},
    {year: 2018, count: 17153}, {year: 2019, count: 17813}, {year: 2020, count: 17943},
    {year: 2021, count: 21085}, {year: 2022, count: 25375}, {year: 2023, count: 31455},
    {year: 2024, count: 41166}
  ];

  // IoT data (source: DemandSage / Statista)
  const iotData = [
    {year: 2016, count: 4.6}, {year: 2017, count: 6.1}, {year: 2018, count: 8.0},
    {year: 2019, count: 10.0}, {year: 2020, count: 11.7}, {year: 2021, count: 13.8},
    {year: 2022, count: 13.8}, {year: 2023, count: 15.7}, {year: 2024, count: 17.7},
    {year: 2025, count: 19.8}
  ];

  function drawChart(containerId, data, color, darkColor, title, yLabel, formatFn) {
    const margin = {top: 38, right: 20, bottom: 38, left: 58};
    const width = 480 - margin.left - margin.right;
    const height = 280 - margin.top - margin.bottom;

    const svg = d3.select(containerId).append("svg")
      .attr("viewBox", "0 0 480 280").attr("width", "100%")
      .append("g").attr("transform", "translate(" + margin.left + "," + margin.top + ")");

    // Title
    svg.append("text").attr("x", width/2).attr("y", -18)
      .attr("text-anchor", "middle").style("font-size", "14px")
      .style("font-weight", "700").style("fill", darkColor).text(title);

    const x = d3.scaleLinear()
      .domain(d3.extent(data, function(d) { return d.year; }))
      .range([0, width]);
    const y = d3.scaleLinear()
      .domain([0, d3.max(data, function(d) { return d.count; }) * 1.12])
      .range([height, 0]);

    // Grid lines
    svg.selectAll(".grid").data(y.ticks(5)).enter().append("line")
      .attr("x1", 0).attr("x2", width)
      .attr("y1", function(d) { return y(d); }).attr("y2", function(d) { return y(d); })
      .attr("stroke", "#eee").attr("stroke-width", 1);

    // Area fill
    var area = d3.area()
      .x(function(d) { return x(d.year); })
      .y0(height)
      .y1(function(d) { return y(d.count); })
      .curve(d3.curveMonotoneX);
    svg.append("path").datum(data).attr("d", area)
      .attr("fill", color).attr("opacity", 0.15);

    // Line
    var line = d3.line()
      .x(function(d) { return x(d.year); })
      .y(function(d) { return y(d.count); })
      .curve(d3.curveMonotoneX);
    svg.append("path").datum(data).attr("d", line)
      .attr("fill", "none").attr("stroke", color).attr("stroke-width", 3);

    // Dots
    svg.selectAll(".dot").data(data).enter().append("circle")
      .attr("cx", function(d) { return x(d.year); })
      .attr("cy", function(d) { return y(d.count); })
      .attr("r", 4).attr("fill", color).attr("stroke", "white").attr("stroke-width", 1.5);

    // Last point label
    var last = data[data.length - 1];
    svg.append("text")
      .attr("x", x(last.year)).attr("y", y(last.count) - 12)
      .attr("text-anchor", "middle").style("font-size", "13px")
      .style("font-weight", "800").style("fill", darkColor)
      .text(formatFn(last.count));

    // Axes
    svg.append("g").attr("transform", "translate(0," + height + ")")
      .call(d3.axisBottom(x).ticks(5).tickFormat(d3.format("d")).tickSize(-3))
      .selectAll("text").style("font-size", "11px").style("fill", "#555");
    svg.append("g")
      .call(d3.axisLeft(y).ticks(5).tickFormat(formatFn).tickSize(-3))
      .selectAll("text").style("font-size", "10px").style("fill", "#555");
    svg.selectAll(".domain").attr("stroke", "#ccc");

    // Y-axis label
    svg.append("text").attr("transform", "rotate(-90)")
      .attr("y", -45).attr("x", -height/2)
      .attr("text-anchor", "middle").style("font-size", "10px").style("fill", "#888")
      .text(yLabel);
  }

  drawChart("#chart-cve", cveData, "#E53935", "#B71C1C",
    "Published CVEs per Year", "CVEs",
    function(d) { return d >= 1000 ? (d/1000).toFixed(d >= 10000 ? 0 : 1) + "K" : d; });

  drawChart("#chart-iot", iotData, "#2196F3", "#1565C0",
    "Connected IoT Devices (Billions)", "Devices (B)",
    function(d) { return d.toFixed(1) + "B"; });
});
</script>
        </div>
    </div>
    
    <div class="slide-footnote">[1] <a href='https://www.cvefind.com/en/cve-statistic-date.html'>cvefind.com/en/cve-statistic-date.html</a>&emsp;[2] <a href='https://www.demandsage.com/number-of-iot-devices/'>demandsage.com/number-of-iot-devices</a></div>
    
</div>
        
<div class="slide flex flex-col" id="slide-3">
    <div class="bg-maroon text-white font-normal px-10 md:px-14 py-5 md:py-7 border-b-4 border-maroon-dark shrink-0" style="font-size: clamp(3.3rem, 5.7vw, 4.8rem);">
        Precision & Recall
    </div>
    <div class="flex-1 px-8 md:px-12 py-3 md:py-5 overflow-hidden flex flex-col justify-center">
        <div class="slide-body">
            <svg id="pr-venn" viewBox="0 0 900 580" style="width:85%; margin:0 auto; display:block;" xmlns="http://www.w3.org/2000/svg">

  <!-- "relevant elements" bracket label -->
  <text x="250" y="30" text-anchor="middle" font-family="Inter, sans-serif" font-size="15" fill="#555" font-weight="600">relevant elements</text>
  <line x1="65" y1="42" x2="65" y2="50" stroke="#888" stroke-width="1.5"/>
  <line x1="65" y1="42" x2="435" y2="42" stroke="#888" stroke-width="1.5"/>
  <line x1="435" y1="42" x2="435" y2="50" stroke="#888" stroke-width="1.5"/>

  <!-- Base rectangle (relevant elements) and ellipse (retrieved elements) outlines -->
  <rect x="50" y="55" width="400" height="330" rx="4" fill="#f0f0f0" stroke="#bbb" stroke-width="1.5"/>
  <ellipse cx="430" cy="220" rx="250" ry="155" fill="none" stroke="#777" stroke-width="2"/>

  <!-- "retrieved elements" label -->
  <text x="430" y="405" text-anchor="middle" font-family="Inter, sans-serif" font-size="15" fill="#555" font-weight="600">retrieved elements</text>

  <!-- STEP 1: True Positives (green zone in overlap) -->
  <g id="pr-tp" opacity="0">
    <!-- Approximate green fill for overlap: a rect covering the intersection area -->
    <rect x="230" y="80" width="220" height="280" rx="4" fill="#a5d6a7" opacity="0.55"/>
    <!-- Green dots -->
    <circle cx="290" cy="140" r="10" fill="#2e7d32"/>
    <circle cx="340" cy="120" r="10" fill="#2e7d32"/>
    <circle cx="370" cy="180" r="10" fill="#2e7d32"/>
    <circle cx="310" cy="210" r="10" fill="#2e7d32"/>
    <circle cx="400" cy="160" r="10" fill="#2e7d32"/>
    <circle cx="280" cy="280" r="10" fill="#2e7d32"/>
    <circle cx="350" cy="260" r="10" fill="#2e7d32"/>
    <circle cx="320" cy="330" r="10" fill="#2e7d32"/>
    <text x="340" y="235" text-anchor="middle" font-family="Inter, sans-serif" font-size="15" fill="#1b5e20" font-weight="700">true positives</text>
  </g>

  <!-- STEP 2: False Positives (red zone, right side of ellipse outside rect) -->
  <g id="pr-fp" opacity="0">
    <!-- Approximate pink fill for FP region -->
    <ellipse cx="560" cy="220" rx="110" ry="140" fill="#ef9a9a" opacity="0.45"/>
    <!-- Hollow red dots -->
    <circle cx="530" cy="140" r="10" fill="none" stroke="#c62828" stroke-width="2.5"/>
    <circle cx="580" cy="190" r="10" fill="none" stroke="#c62828" stroke-width="2.5"/>
    <circle cx="560" cy="260" r="10" fill="none" stroke="#c62828" stroke-width="2.5"/>
    <circle cx="610" cy="230" r="10" fill="none" stroke="#c62828" stroke-width="2.5"/>
    <circle cx="520" cy="310" r="10" fill="none" stroke="#c62828" stroke-width="2.5"/>
    <text x="570" cy="170" y="175" text-anchor="middle" font-family="Inter, sans-serif" font-size="15" fill="#b71c1c" font-weight="700">false positives</text>
  </g>

  <!-- STEP 3: False Negatives (left side of rect, outside ellipse) -->
  <g id="pr-fn" opacity="0">
    <circle cx="110" cy="120" r="10" fill="#616161"/>
    <circle cx="150" cy="180" r="10" fill="#616161"/>
    <circle cx="90" cy="240" r="10" fill="#616161"/>
    <circle cx="130" cy="300" r="10" fill="#616161"/>
    <circle cx="180" cy="130" r="10" fill="#616161"/>
    <circle cx="100" cy="350" r="10" fill="#616161"/>
    <circle cx="200" cy="340" r="10" fill="#616161"/>
    <text x="145" y="215" text-anchor="middle" font-family="Inter, sans-serif" font-size="15" fill="#424242" font-weight="700">false negatives</text>
  </g>

  <!-- STEP 4: True Negatives (outside both, upper right) -->
  <g id="pr-tn" opacity="0">
    <circle cx="760" cy="80" r="9" fill="none" stroke="#999" stroke-width="2"/>
    <circle cx="800" cy="140" r="9" fill="none" stroke="#999" stroke-width="2"/>
    <circle cx="780" cy="210" r="9" fill="none" stroke="#999" stroke-width="2"/>
    <circle cx="820" cy="280" r="9" fill="none" stroke="#999" stroke-width="2"/>
    <circle cx="750" cy="330" r="9" fill="none" stroke="#999" stroke-width="2"/>
    <text x="790" y="60" text-anchor="middle" font-family="Inter, sans-serif" font-size="15" fill="#757575" font-weight="700">true negatives</text>
  </g>

  <!-- STEP 5: Equations -->
  <g id="pr-equations" opacity="0">
    <line x1="50" y1="430" x2="850" y2="430" stroke="#ddd" stroke-width="1"/>
    <text x="220" y="470" text-anchor="middle" font-family="Inter, sans-serif" font-size="13" fill="#777">How many retrieved items are relevant?</text>
    <text x="220" y="510" text-anchor="middle" font-family="Inter, sans-serif" font-size="22" font-weight="700" fill="#1565c0">Precision = TP / (TP + FP)</text>
    <text x="670" y="470" text-anchor="middle" font-family="Inter, sans-serif" font-size="13" fill="#777">How many relevant items are retrieved?</text>
    <text x="670" y="510" text-anchor="middle" font-family="Inter, sans-serif" font-size="22" font-weight="700" fill="#2e7d32">Recall = TP / (TP + FN)</text>
  </g>
</svg>
<script>
window._animQueue.push(function() {
  var el = document.getElementById('pr-venn');
  console.log('[PR-VENN] el=', el);
  if (!el) return;
  var slideEl = el.closest('.slide');
  console.log('[PR-VENN] slideEl=', slideEl);
  if (!slideEl) return;
  var slides = document.querySelectorAll('.slide');
  var idx = Array.from(slides).indexOf(slideEl);
  console.log('[PR-VENN] idx=', idx, 'total slides=', slides.length);
  if (idx < 0) return;
  console.log('[PR-VENN] registering 5-step animation at index', idx);

  // Test: force-show pr-tp after 3s to verify SVG rendering works at all
  setTimeout(function() {
    var tp = document.getElementById('pr-tp');
    console.log('[PR-VENN] AUTO-TEST: forcing pr-tp visible, el=', tp);
    if (tp) {
      tp.setAttribute('opacity', '1');
      tp.style.opacity = '1';
      console.log('[PR-VENN] AUTO-TEST: pr-tp opacity now:', tp.getAttribute('opacity'), getComputedStyle(tp).opacity);
    }
  }, 3000);

  window.registerSlideAnimation(idx, {
    mode: 'step',
    steps: [
      makeStep(['pr-tp']),
      makeStep(['pr-fp']),
      makeStep(['pr-fn']),
      makeStep(['pr-tn']),
      makeStep(['pr-equations'])
    ]
  });
});
</script>
        </div>
    </div>
    
</div>
        
<div class="slide flex flex-col" id="slide-4">
    <div class="bg-maroon text-white font-normal px-10 md:px-14 py-5 md:py-7 border-b-4 border-maroon-dark shrink-0" style="font-size: clamp(3.3rem, 5.7vw, 4.8rem);">
        Staged Evidence: Achieving Both
    </div>
    <div class="flex-1 px-8 md:px-12 py-3 md:py-5 overflow-hidden flex flex-col justify-center">
        <div class="slide-body">
            <svg viewBox="0 0 1000 420" style="width:100%; margin:0.5rem auto; display:block;" xmlns="http://www.w3.org/2000/svg">
  <defs>
    <marker id="arrStage" markerWidth="10" markerHeight="10" refX="8" refY="3" orient="auto" markerUnits="strokeWidth">
      <path d="M0,0 L0,6 L9,3 z" fill="#8C1D40"/>
    </marker>
  </defs>

  <!-- Stage 1: Detection -->
  <g>
    <!-- Card -->
    <rect x="20" y="50" width="290" height="280" rx="10" fill="#e3f2fd" stroke="#2196F3" stroke-width="2.5"/>
    <!-- Header bar -->
    <rect x="20" y="50" width="290" height="45" rx="10" fill="#2196F3"/>
    <rect x="20" y="75" width="290" height="20" fill="#2196F3"/>
    <text x="165" y="80" text-anchor="middle" font-size="17" font-weight="700" fill="white" font-family="Inter, sans-serif">DETECTION</text>
    <!-- Goal -->
    <text x="165" y="120" text-anchor="middle" font-size="13" font-weight="600" fill="#1565C0" font-family="Inter, sans-serif">Goal: Capture all candidates</text>
    <!-- Dots: many, mixed colors (true + false positives) -->
    <g transform="translate(55, 140)">
      <!-- True positives (green) -->
      <circle cx="15" cy="10" r="8" fill="#4CAF50" opacity="0.7"/>
      <circle cx="55" cy="25" r="8" fill="#4CAF50" opacity="0.7"/>
      <circle cx="130" cy="15" r="8" fill="#4CAF50" opacity="0.7"/>
      <circle cx="95" cy="55" r="8" fill="#4CAF50" opacity="0.7"/>
      <circle cx="170" cy="50" r="8" fill="#4CAF50" opacity="0.7"/>
      <!-- False positives (red) -->
      <circle cx="40" cy="10" r="8" fill="#E53935" opacity="0.5"/>
      <circle cx="80" cy="20" r="8" fill="#E53935" opacity="0.5"/>
      <circle cx="155" cy="35" r="8" fill="#E53935" opacity="0.5"/>
      <circle cx="25" cy="45" r="8" fill="#E53935" opacity="0.5"/>
      <circle cx="110" cy="40" r="8" fill="#E53935" opacity="0.5"/>
      <circle cx="60" cy="55" r="8" fill="#E53935" opacity="0.5"/>
      <circle cx="140" cy="55" r="8" fill="#E53935" opacity="0.5"/>
      <circle cx="195" cy="20" r="8" fill="#E53935" opacity="0.5"/>
      <circle cx="195" cy="50" r="8" fill="#E53935" opacity="0.5"/>
    </g>
    <!-- Metric -->
    <rect x="50" y="265" width="210" height="40" rx="6" fill="white" stroke="#2196F3" stroke-width="1.5"/>
    <text x="165" y="282" text-anchor="middle" font-size="12" font-weight="700" fill="#1565C0" font-family="Inter, sans-serif">Recall (Completeness)</text>
    <text x="165" y="298" text-anchor="middle" font-size="11" fill="#555" font-family="Inter, sans-serif">Tolerate false positives to miss nothing</text>
  </g>

  <!-- Arrow 1→2 -->
  <path d="M 310 190 L 350 190" stroke="#8C1D40" stroke-width="3" fill="none" marker-end="url(#arrStage)"/>

  <!-- Stage 2: Validation -->
  <g>
    <!-- Card -->
    <rect x="355" y="50" width="290" height="280" rx="10" fill="#fff3e0" stroke="#FF9800" stroke-width="2.5"/>
    <!-- Header bar -->
    <rect x="355" y="50" width="290" height="45" rx="10" fill="#FF9800"/>
    <rect x="355" y="75" width="290" height="20" fill="#FF9800"/>
    <text x="500" y="80" text-anchor="middle" font-size="17" font-weight="700" fill="white" font-family="Inter, sans-serif">VALIDATION</text>
    <!-- Goal -->
    <text x="500" y="120" text-anchor="middle" font-size="13" font-weight="600" fill="#E65100" font-family="Inter, sans-serif">Goal: Eliminate false alarms</text>
    <!-- Dots: fewer, mostly green, some red being crossed out -->
    <g transform="translate(390, 140)">
      <!-- True positives (green, kept) -->
      <circle cx="30" cy="20" r="10" fill="#4CAF50" opacity="0.8"/>
      <circle cx="100" cy="15" r="10" fill="#4CAF50" opacity="0.8"/>
      <circle cx="65" cy="50" r="10" fill="#4CAF50" opacity="0.8"/>
      <circle cx="140" cy="40" r="10" fill="#4CAF50" opacity="0.8"/>
      <circle cx="180" cy="20" r="10" fill="#4CAF50" opacity="0.8"/>
      <!-- False positives being pruned (red, with strikethrough) -->
      <circle cx="60" cy="15" r="8" fill="#E53935" opacity="0.25"/>
      <line x1="52" y1="7" x2="68" y2="23" stroke="#E53935" stroke-width="2" opacity="0.6"/>
      <circle cx="150" cy="15" r="8" fill="#E53935" opacity="0.25"/>
      <line x1="142" y1="7" x2="158" y2="23" stroke="#E53935" stroke-width="2" opacity="0.6"/>
      <circle cx="110" cy="50" r="8" fill="#E53935" opacity="0.25"/>
      <line x1="102" y1="42" x2="118" y2="58" stroke="#E53935" stroke-width="2" opacity="0.6"/>
    </g>
    <!-- Metric -->
    <rect x="385" y="265" width="210" height="40" rx="6" fill="white" stroke="#FF9800" stroke-width="1.5"/>
    <text x="500" y="282" text-anchor="middle" font-size="12" font-weight="700" fill="#E65100" font-family="Inter, sans-serif">Precision (Accuracy)</text>
    <text x="500" y="298" text-anchor="middle" font-size="11" fill="#555" font-family="Inter, sans-serif">Corroborate and prune mercilessly</text>
  </g>

  <!-- Arrow 2→3 -->
  <path d="M 645 190 L 685 190" stroke="#8C1D40" stroke-width="3" fill="none" marker-end="url(#arrStage)"/>

  <!-- Stage 3: Confirmation -->
  <g>
    <!-- Card -->
    <rect x="690" y="50" width="290" height="280" rx="10" fill="#e8f5e9" stroke="#4CAF50" stroke-width="2.5"/>
    <!-- Header bar -->
    <rect x="690" y="50" width="290" height="45" rx="10" fill="#4CAF50"/>
    <rect x="690" y="75" width="290" height="20" fill="#4CAF50"/>
    <text x="835" y="80" text-anchor="middle" font-size="17" font-weight="700" fill="white" font-family="Inter, sans-serif">CONFIRMATION</text>
    <!-- Goal -->
    <text x="835" y="120" text-anchor="middle" font-size="13" font-weight="600" fill="#2E7D32" font-family="Inter, sans-serif">Goal: Produce proof</text>
    <!-- Dots: few, all green, with checkmarks -->
    <g transform="translate(725, 140)">
      <circle cx="40" cy="25" r="12" fill="#4CAF50" opacity="0.9"/>
      <text x="40" y="30" text-anchor="middle" font-size="12" fill="white" font-weight="bold">✓</text>
      <circle cx="110" cy="20" r="12" fill="#4CAF50" opacity="0.9"/>
      <text x="110" y="25" text-anchor="middle" font-size="12" fill="white" font-weight="bold">✓</text>
      <circle cx="75" cy="55" r="12" fill="#4CAF50" opacity="0.9"/>
      <text x="75" y="60" text-anchor="middle" font-size="12" fill="white" font-weight="bold">✓</text>
      <circle cx="155" cy="45" r="12" fill="#4CAF50" opacity="0.9"/>
      <text x="155" y="50" text-anchor="middle" font-size="12" fill="white" font-weight="bold">✓</text>
    </g>
    <!-- Metric -->
    <rect x="720" y="265" width="210" height="40" rx="6" fill="white" stroke="#4CAF50" stroke-width="1.5"/>
    <text x="835" y="282" text-anchor="middle" font-size="12" font-weight="700" fill="#2E7D32" font-family="Inter, sans-serif">Proof-of-Concept</text>
    <text x="835" y="298" text-anchor="middle" font-size="11" fill="#555" font-family="Inter, sans-serif">Concrete triggering input per vulnerability</text>
  </g>

  <!-- Bottom: Legend -->
  <circle cx="340" cy="375" r="7" fill="#4CAF50" opacity="0.7"/>
  <text x="355" y="380" font-size="12" fill="#555" font-family="Inter, sans-serif">True vulnerability</text>
  <circle cx="510" cy="375" r="7" fill="#E53935" opacity="0.5"/>
  <text x="525" y="380" font-size="12" fill="#555" font-family="Inter, sans-serif">False positive</text>

  <!-- Bottom: Key insight -->
  <text x="500" y="410" text-anchor="middle" font-size="14" font-weight="600" fill="#333" font-family="Inter, sans-serif" font-style="italic">Assign each metric to its own stage. Layer the stages in sequence.</text>
</svg>
        </div>
    </div>
    
</div>
        
<div class="slide flex flex-col" id="slide-5">
    <div class="bg-maroon text-white font-normal px-10 md:px-14 py-5 md:py-7 border-b-4 border-maroon-dark shrink-0" style="font-size: clamp(3.3rem, 5.7vw, 4.8rem);">
        Existing Tools: Pick Two
    </div>
    <div class="flex-1 px-8 md:px-12 py-3 md:py-5 overflow-hidden flex flex-col justify-center">
        <div class="slide-body">
            <div style="display:flex; gap:0; align-items:center; justify-content:center; height:88vh; padding:0; margin:0;">
  <!-- LEFT: Radar chart -->
  <div id="radar-container" style="flex:1 1 auto; height:100%; min-width:0;"></div>

  <!-- RIGHT: Legend + insight -->
  <div id="radar-legend" style="flex:0 0 560px; margin-left:-80px; display:flex; flex-direction:column; justify-content:center; gap:2.2rem; opacity:0; transition: opacity 0.4s;">

    <div style="font-size:34px; font-weight:700; color:#333; font-family:Inter,sans-serif; margin-bottom:0.5rem;">Tool Profiles</div>

    <div id="legend-static" style="display:flex; align-items:center; gap:14px; opacity:0; transition: opacity 0.3s;">
      <div style="width:30px; height:30px; border-radius:4px; background:#2196F3; flex-shrink:0;"></div>
      <div>
        <div style="font-size:30px; font-weight:700; color:#1565C0; font-family:Inter,sans-serif;">Static Analysis</div>
        <div style="font-size:26px; color:#666; font-family:Inter,sans-serif;">Sweeps everything. Reports noise.</div>
      </div>
    </div>

    <div id="legend-fuzz" style="display:flex; align-items:center; gap:14px; opacity:0; transition: opacity 0.3s;">
      <div style="width:30px; height:30px; border-radius:4px; background:#FF9800; flex-shrink:0;"></div>
      <div>
        <div style="font-size:30px; font-weight:700; color:#E65100; font-family:Inter,sans-serif;">Fuzzing</div>
        <div style="font-size:26px; color:#666; font-family:Inter,sans-serif;">Real crashes, opportunistic coverage.</div>
      </div>
    </div>

    <div id="legend-symex" style="display:flex; align-items:center; gap:14px; opacity:0; transition: opacity 0.3s;">
      <div style="width:30px; height:30px; border-radius:4px; background:#7B1FA2; flex-shrink:0;"></div>
      <div>
        <div style="font-size:30px; font-weight:700; color:#7B1FA2; font-family:Inter,sans-serif;">Symbolic Execution</div>
        <div style="font-size:26px; color:#666; font-family:Inter,sans-serif;">Proves reachability. Chokes on scale.</div>
      </div>
    </div>

    <div id="legend-ideal" style="display:flex; align-items:center; gap:14px; opacity:0; transition: opacity 0.3s; margin-top:0.5rem; padding-top:1rem; border-top:1px solid #eee;">
      <div style="width:30px; height:30px; border-radius:50%; border:2.5px dashed #8C1D40; flex-shrink:0;"></div>
      <div>
        <div style="font-size:30px; font-weight:700; color:#8C1D40; font-family:Inter,sans-serif;">Ideal Analysis</div>
        <div style="font-size:26px; color:#666; font-family:Inter,sans-serif;">Where we want to be.</div>
      </div>
    </div>

    <div id="legend-insight" style="opacity:0; transition: opacity 0.3s; margin-top:1rem; padding:16px 18px; background:#fafafa; border-left:3px solid #8C1D40; border-radius:0 6px 6px 0;">
      <div style="font-size:28px; color:#333; font-family:Inter,sans-serif; font-style:italic; line-height:1.5;">No single tool fills all three axes. The thesis: layer them in sequence.</div>
    </div>
  </div>
</div>
<script>
window._animQueue.push(function() {
  var container = document.getElementById('radar-container');
  if (!container) return;

  var slideEl = container.closest('.slide');
  var slides = document.querySelectorAll('.slide');
  var slideIdx = Array.from(slides).indexOf(slideEl);
  if (slideIdx < 0) return;

  // --- Radar chart setup ---
  var size = 600;
  var cx = size / 2, cy = size / 2 + 15;
  var maxR = 260;
  var levels = 5;
  var axes = [
    { key: 'accuracy',     label: 'Accuracy',     angle: -Math.PI / 2 },
    { key: 'completeness', label: 'Completeness', angle: -Math.PI / 2 + (2 * Math.PI / 3) },
    { key: 'scalability',  label: 'Scalability',  angle: -Math.PI / 2 + (4 * Math.PI / 3) }
  ];

  // Order: static, fuzzing, symex (animation order)
  var tools = [
    { id: 'static', label: 'Static Analysis',    color: '#2196F3', fillColor: 'rgba(33,150,243,0.12)',
      accuracy: 0.15, completeness: 0.85, scalability: 0.9 },
    { id: 'fuzz',   label: 'Fuzzing',            color: '#FF9800', fillColor: 'rgba(255,152,0,0.12)',
      accuracy: 0.55, completeness: 0.5, scalability: 0.5 },
    { id: 'symex',  label: 'Symbolic Execution', color: '#7B1FA2', fillColor: 'rgba(123,31,162,0.12)',
      accuracy: 0.9, completeness: 0.25, scalability: 0.15 }
  ];
  var ideal = { accuracy: 0.9, completeness: 0.9, scalability: 0.9 };

  var svg = d3.select('#radar-container')
    .append('svg')
    .attr('viewBox', '-60 -20 720 650')
    .attr('preserveAspectRatio', 'xMidYMid meet')
    .style('width', '100%')
    .style('height', '100%');

  // Grid rings
  for (var lvl = 1; lvl <= levels; lvl++) {
    var r = (maxR / levels) * lvl;
    var pts = axes.map(function(a) {
      return (cx + r * Math.cos(a.angle)) + ',' + (cy + r * Math.sin(a.angle));
    }).join(' ');
    svg.append('polygon')
      .attr('points', pts)
      .attr('fill', 'none')
      .attr('stroke', '#e0e0e0')
      .attr('stroke-width', lvl === levels ? 1.5 : 0.8);
  }

  // Axis lines + labels
  axes.forEach(function(a) {
    var ex = cx + maxR * Math.cos(a.angle);
    var ey = cy + maxR * Math.sin(a.angle);
    svg.append('line')
      .attr('x1', cx).attr('y1', cy)
      .attr('x2', ex).attr('y2', ey)
      .attr('stroke', '#ccc')
      .attr('stroke-width', 1.5);

    // Label
    var lx = cx + (maxR + 40) * Math.cos(a.angle);
    var ly = cy + (maxR + 40) * Math.sin(a.angle);
    svg.append('text')
      .attr('x', lx).attr('y', ly + 7)
      .attr('text-anchor', 'middle')
      .attr('font-size', 26)
      .attr('font-weight', 700)
      .attr('fill', '#333')
      .attr('font-family', 'Inter, sans-serif')
      .text(a.label);
  });

  // Helper: get polygon points for a data object
  function getPoints(d) {
    return axes.map(function(a) {
      var val = d[a.key];
      var r = val * maxR;
      return (cx + r * Math.cos(a.angle)) + ',' + (cy + r * Math.sin(a.angle));
    }).join(' ');
  }

  // Create tool polygons (hidden initially)
  var toolPolygons = [];
  tools.forEach(function(t) {
    var g = svg.append('g').attr('id', 'radar-' + t.id).attr('opacity', 0);
    g.append('polygon')
      .attr('points', getPoints({ accuracy:0, completeness:0, scalability:0 }))
      .attr('fill', t.fillColor)
      .attr('stroke', t.color)
      .attr('stroke-width', 2.5);

    // Vertex dots
    axes.forEach(function(a) {
      g.append('circle')
        .attr('class', 'vertex-dot')
        .attr('cx', cx).attr('cy', cy)
        .attr('r', 6)
        .attr('fill', t.color);
    });

    toolPolygons.push(g);
  });

  // Ideal polygon (hidden)
  var idealGroup = svg.append('g').attr('id', 'radar-ideal').attr('opacity', 0);
  idealGroup.append('polygon')
    .attr('points', getPoints({ accuracy:0, completeness:0, scalability:0 }))
    .attr('fill', 'none')
    .attr('stroke', '#8C1D40')
    .attr('stroke-width', 2.5)
    .attr('stroke-dasharray', '8,4');

  // Animation functions
  function animatePolygonIn(group, data, color, duration) {
    duration = duration || 600;
    group.attr('opacity', 1);
    group.select('polygon')
      .transition()
      .duration(duration)
      .ease(d3.easeCubicOut)
      .attr('points', getPoints(data));

    // Animate vertex dots
    var dots = group.selectAll('.vertex-dot');
    dots.each(function(d, i) {
      var a = axes[i];
      var val = data[a.key];
      d3.select(this)
        .transition()
        .duration(duration)
        .ease(d3.easeCubicOut)
        .attr('cx', cx + val * maxR * Math.cos(a.angle))
        .attr('cy', cy + val * maxR * Math.sin(a.angle));
    });
  }

  // Register step animations
  window.registerSlideAnimation(slideIdx, {
    mode: 'step',
    steps: [
      // Step 1: Show legend + Static Analysis
      {
        show: function(instant) {
          document.getElementById('radar-legend').style.opacity = '1';
          document.getElementById('legend-static').style.opacity = '1';
          var dur = instant ? 0 : 600;
          animatePolygonIn(toolPolygons[0], tools[0], tools[0].color, dur);
        },
        hide: function() {
          toolPolygons[0].attr('opacity', 0)
            .select('polygon').attr('points', getPoints({accuracy:0,completeness:0,scalability:0}));
          toolPolygons[0].selectAll('.vertex-dot').attr('cx', cx).attr('cy', cy);
          document.getElementById('legend-static').style.opacity = '0';
        }
      },
      // Step 2: Fuzzing
      {
        show: function(instant) {
          document.getElementById('legend-fuzz').style.opacity = '1';
          var dur = instant ? 0 : 600;
          animatePolygonIn(toolPolygons[1], tools[1], tools[1].color, dur);
        },
        hide: function() {
          toolPolygons[1].attr('opacity', 0)
            .select('polygon').attr('points', getPoints({accuracy:0,completeness:0,scalability:0}));
          toolPolygons[1].selectAll('.vertex-dot').attr('cx', cx).attr('cy', cy);
          document.getElementById('legend-fuzz').style.opacity = '0';
        }
      },
      // Step 3: Symbolic Execution
      {
        show: function(instant) {
          document.getElementById('legend-symex').style.opacity = '1';
          var dur = instant ? 0 : 600;
          animatePolygonIn(toolPolygons[2], tools[2], tools[2].color, dur);
        },
        hide: function() {
          toolPolygons[2].attr('opacity', 0)
            .select('polygon').attr('points', getPoints({accuracy:0,completeness:0,scalability:0}));
          toolPolygons[2].selectAll('.vertex-dot').attr('cx', cx).attr('cy', cy);
          document.getElementById('legend-symex').style.opacity = '0';
        }
      },
      // Step 4: Ideal + insight
      {
        show: function(instant) {
          document.getElementById('legend-ideal').style.opacity = '1';
          document.getElementById('legend-insight').style.opacity = '1';
          var dur = instant ? 0 : 600;
          idealGroup.attr('opacity', 1);
          idealGroup.select('polygon')
            .transition()
            .duration(dur)
            .ease(d3.easeCubicOut)
            .attr('points', getPoints(ideal));
        },
        hide: function() {
          idealGroup.attr('opacity', 0)
            .select('polygon').attr('points', getPoints({accuracy:0,completeness:0,scalability:0}));
          document.getElementById('legend-ideal').style.opacity = '0';
          document.getElementById('legend-insight').style.opacity = '0';
        }
      }
    ]
  });
});
</script>
        </div>
    </div>
    
</div>
        
<div class="slide flex flex-col" id="slide-6">
    <div class="bg-maroon text-white font-normal px-10 md:px-14 py-5 md:py-7 border-b-4 border-maroon-dark shrink-0" style="font-size: clamp(3.3rem, 5.7vw, 4.8rem);">
        The Detection-to-Confirmation Gap
    </div>
    <div class="flex-1 px-8 md:px-12 py-3 md:py-5 overflow-hidden flex flex-col justify-center">
        <div class="slide-body">
            <svg viewBox="0 0 1000 300" style="width:100%; margin:0.5rem auto 0.5rem auto; display:block;">
  <defs>
    <marker id="arrGap" markerWidth="10" markerHeight="10" refX="7" refY="3" orient="auto" markerUnits="strokeWidth">
      <path d="M0,0 L0,6 L9,3 z" fill="#888"/>
    </marker>
  </defs>

  <!-- Detection box -->
  <rect x="30" y="80" width="200" height="90" fill="#e3f2fd" stroke="#2196F3" stroke-width="2.5" rx="8"/>
